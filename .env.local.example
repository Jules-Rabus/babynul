# Connection Postgres (Supabase) — utilisée par Prisma côté serveur uniquement.
# Ces deux variables sont provisionnées automatiquement par l'intégration
# Vercel ↔ Supabase (Marketplace). En local, copier les valeurs depuis :
# Supabase → Project settings → Database → Connection string.
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Code admin qui débloque la saisie de matchs, la gestion des joueurs,
# et l'édition du prompt du voice mode.
# Pas de préfixe NEXT_PUBLIC_ : le code n'est jamais envoyé au navigateur,
# il est validé côté serveur via une Server Action qui pose un cookie httpOnly.
ADMIN_CODE=

# Voice mode — clés LLM + TTS. Gemini primaire, OpenAI fallback.
VOICE_PROVIDER=gemini
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
