# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Code admin qui débloque la saisie de matchs et la gestion des joueurs.
# Pas de préfixe NEXT_PUBLIC_ : le code n'est jamais envoyé au navigateur,
# il est validé côté serveur via une Server Action qui pose un cookie httpOnly.
ADMIN_CODE=
