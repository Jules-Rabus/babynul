# Supabase project URL (from the "Connect" dialog in your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co

# Publishable API key (new format) - from Project Settings > API Keys > Publishable
# Fallback to the legacy anon key is supported if you're still on the old format.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

